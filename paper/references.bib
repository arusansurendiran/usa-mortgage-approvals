@article{moubadder2024increasing,
        author={Moubadder,Leah and Bliss,Maya and Maliniak,Maret L. and Waddel,Hannah and Switchenko,Jeffery M. and Chang,Howard H. and Kramer,Michael R. and McCullough,Lauren E.},
        title={Increasing Access, Equitability, and Rigor in the Assessment of Neighborhood Mortgage Discrimination: Increasing Access, Equitability, and Rigor in the Assessment of Neighborhood Mortgage Discrimination},
        journal={Journal of urban health},
        volume={101},
        number={6},
        pages={1274-1278},
        note={ID: cdi_scopus_primary_2_s2_0_85210478749},
        abstract={Mortgage discrimination alters the distribution of investment, opportunity, and economic advantage—key contributors of health disparities. Leveraging Home Mortgage Disclosure Act data, we assessed mortgage denial risk in 380 U.S. urban areas. We estimated the risks by census tract–relative to the urban-specific average—using a Bayesian spatial model with conditionally autoregressive distributions fitted with integrated nested Laplace approximation. This approach borrows information through spatial and non-spatial smoothing, resulting in stable estimates in the presence of sparse data. The method, publicly accessible, allows researchers to apply our approach, fostering deeper insights into mortgage lending discrimination and systematic neighborhood disinvestment.},
        keywords={Neighborhood Characteristics; Neighborhoods; Bayes Theorem; Bayesian analysis; Bioinformatics; Biostatistics; Brief Report; Censuses; Data smoothing; Disclosure; Discrimination; Epidemiology; General & Internal Medicine; Health disparities; Health Informatics; Home financing; Home ownership; Housing; Humans; Life Sciences & Biomedicine; Loans; Medicine; Medicine & Public Health; Medicine, General & Internal; Mortgages; Public Health; Public, Environmental & Occupational Health; Residence Characteristics; Risk assessment; Science & Technology; Spatial data; Spatial smoothing; United States; Urban areas},
        isbn={1099-3460},
       doi={10.1007/s11524-024-00941-0},
       year={2024},
}
